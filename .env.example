# Django
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Database (Railway sets DATABASE_URL automatically)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Email — Resend HTTP API (recommended on Railway; SMTP port 587 is often blocked)
# 1. Sign up at https://resend.com and create an API key
# 2. For testing: DEFAULT_FROM_EMAIL with onboarding@resend.dev (sends to your Resend account email only)
# 3. For production: verify eliteelectronicssolutions.com in Resend, then use bookings@...
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
DEFAULT_FROM_EMAIL=Elite Electronics Solutions <onboarding@resend.dev>

# Email — Gmail (works locally; often blocked from Railway)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your16charapppassword
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=Elite Electronics Solutions <your-email@gmail.com>

# OpenAI — get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

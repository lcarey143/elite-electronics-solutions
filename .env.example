# Django
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Database (Railway sets DATABASE_URL automatically)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Email — use Gmail SMTP or a service like Resend/SendGrid
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Elite Electronics Solutions <your-email@gmail.com>

# OpenAI — get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
